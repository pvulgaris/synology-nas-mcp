# Copy to dev/.env.local and set your NAS hostname. dev/.env.local is gitignored.
# Sourced by dev/source-creds.sh before its defaults, so these win over the
# generic nas.local fallbacks — no need to type DSM_BASE_URL on every deploy.
export DSM_BASE_URL=https://your-nas-hostname:5001
# If the daemon binds loopback-only and is fronted by `tailscale serve`, point
# the MCP audit + health endpoints at the serve hostname (tailnet MagicDNS name).
# Otherwise use http://your-nas-hostname:8765/... for a direct 0.0.0.0 bind.
export MCP_AUDIT_URL=https://your-nas-host.your-tailnet.ts.net/audit
export MCP_HEALTH_URL=https://your-nas-host.your-tailnet.ts.net/health
