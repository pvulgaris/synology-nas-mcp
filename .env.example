# Copy this to `.env` on the NAS at /volume1/docker/synology-nas-mcp/.env
# Never commit the real .env — it contains a long-lived 1Password service-account token.

# Required:
OP_SERVICE_ACCOUNT_TOKEN=ops_replace_me
DSM_BASE_URL=https://localhost:5001
DSM_OP_VAULT=your-1password-vault

# Optional (defaults shown):
# DSM_OP_ITEM=Synology DSM - claude-mcp
# DSM_USER=claude-mcp
# MCP_BIND_HOST=                                       # empty = auto-detect (binds 0.0.0.0 here → LAN-reachable).
#                                                      # Set 127.0.0.1 to bind loopback only and front it with
#                                                      # `tailscale serve` (tailnet-only, no LAN exposure). See docs/SETUP.md.
# MCP_BIND_PORT=8765
# MCP_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,null
# TLS_REJECT_UNAUTHORIZED=0

# Optional — Synology router (SRM) target. Unset = NAS-only. The router's
# package/upgrade reads are admin-gated, so SRM_USER must be a dedicated SRM
# admin (claude-mcp-style; used read-only). Put its password + totp in the
# 1Password item named by SRM_OP_ITEM.
# SRM_BASE_URL=https://router.local:8001
# SRM_USER=claude-mcp
# SRM_OP_ITEM=Synology SRM - claude-mcp
