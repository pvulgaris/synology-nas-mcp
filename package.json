{
  "name": "synology-mcp",
  "version": "0.4.0",
  "description": "MCP server for managing a Synology NAS (DSM 7) and SRM router — packages, security audit, shares, storage health, and cross-device update detection. Deploys as a container on the NAS itself; reachable from your Macs over Tailscale.",
  "type": "module",
  "license": "MIT",
  "author": "Peter Vulgaris",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pvulgaris/synology-mcp.git"
  },
  "homepage": "https://github.com/pvulgaris/synology-mcp#readme",
  "bugs": "https://github.com/pvulgaris/synology-mcp/issues",
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "synology",
    "dsm",
    "nas",
    "mcp",
    "model-context-protocol",
    "claude"
  ],
  "bin": {
    "synology-mcp": "dist/cli.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "dev": "tsx src/cli.ts",
    "serve": "node dist/cli.js serve",
    "daemon": "node dist/cli.js daemon",
    "deploy": "tsx src/dev/runner.ts deploy",
    "verify": "tsx src/dev/verify-tools.ts",
    "test": "node --import tsx --test --test-force-exit src/*.test.ts src/tools/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.2.1",
    "otplib": "^12.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.0"
  }
}
